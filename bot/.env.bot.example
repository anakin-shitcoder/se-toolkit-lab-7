# Telegram Bot Configuration
# Copy this file to .env.bot.secret and fill in your values

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# LMS Backend API
LMS_API_URL=http://localhost:8000
LMS_API_KEY=

# LLM API (for intent recognition)
LLM_API_URL=http://localhost:11434
LLM_MODEL=llama3.2

# Bot Settings
BOT_NAME=SE Toolkit Bot
DEBUG_MODE=false
